---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Basic -->
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <title>{title}</title>

  <meta
    name="description"
    content="AdolfMacro | Cybersecurity Enthusiast • Linux Explorer • Python Developer"
  />

  <meta
    name="author"
    content="Mani Kamran"
  />

  <meta
    name="keywords"
    content="AdolfMacro, Mani Kamran, Cybersecurity, Linux, Python, Portfolio, Ethical Hacking, Developer"
  />

  <meta
    name="robots"
    content="index, follow"
  />

  <meta
    name="theme-color"
    content="#0d1117"
  />

  <!-- Open Graph -->
  <meta
    property="og:type"
    content="website"
  />

  <meta
    property="og:title"
    content={title}
  />

  <meta
    property="og:description"
    content="Cybersecurity Enthusiast • Linux Explorer • Python Developer"
  />

  <meta
    property="og:image"
    content="/favicon.ico"
  />

  <!-- Twitter -->
  <meta
    name="twitter:card"
    content="summary_large_image"
  />

  <meta
    name="twitter:title"
    content={title}
  />

  <meta
    name="twitter:description"
    content="Cybersecurity Enthusiast • Linux Explorer • Python Developer"
  />

  <!-- Favicon -->
  <link
    rel="icon"
    type="image/x-icon"
    href="/favicon.ico"
  />

</head>

<body>

  <div class="site-background">

    <div class="cyber-grid"></div>

    <div class="scanline"></div>

    <div class="glow glow-one"></div>

    <div class="glow glow-two"></div>

    <div class="particles">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>

  </div>

  <slot />

</body>

</html>
